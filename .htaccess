Options -MultiViews
RewriteEngine On

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^realtor-campaigns/?$ realtor-campaigns.html [L]
RewriteRule ^homeowner-campaigns/?$ homeowner-campaigns.html [L]
RewriteRule ^cold-outreach/?$ cold-outreach.html [L]
RewriteRule ^about/?$ about.html [L]
RewriteRule ^contact/?$ contact.html [L]
RewriteRule ^thank-you/?$ thank-you.html [L]
